---
// Import team member images
import waleAjani from '../assets/hon-wale-ajani-convener.png';
import mathiasTsado from '../assets/mathia-tsado.png';
import blessingAkinlosotu from '../assets/comrade-blessing-akinlosotu.png';
import laurettaChinenye from '../assets/lauretta-chinenye.png';
import otumbaMichael from '../assets/otumba-micheal.png';
import olalade from '../assets/hon-olalade-john.png';
import abdullahiAngo from '../assets/abdullahi-suleiman-ango.png';
import solaOlofin from '../assets/sola-olofin.png';
import murtalaAdogi from '../assets/murtala-adogi.png';
import ahmedBuhari from '../assets/ahmed-buhari.png';
import olamijuwonAlao from '../assets/olamijuwon-alao.png';
import nafisaAtiku from '../assets/nafisa-atiku.png';
import chamberlainUsoh from '../assets/chamberlain-usoh.png';
import seunOkinbaloye from '../assets/seun-okinbaloye.png';
import adaoraOnyechere from '../assets/adaora-onyechere.png';
import jerryAdesewo from '../assets/omoba jerry-adesewo.png';
import davidOpeyemi from '../assets/david-opeyemi-oke.png';
import emergingLogo from '../assets/emerging-logo.png';
---

<section class="py-16 sm:py-24 bg-gradient-to-br from-emerald-600 via-emerald-700 to-green-800 relative overflow-hidden">
  <!-- Wave Pattern Background -->
  <div class="absolute inset-0 opacity-10">
    <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="wave-pattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
          <path d="M0 50 Q 25 25, 50 50 T 100 50" stroke="rgba(255,255,255,0.3)" fill="none" stroke-width="1"/>
          <path d="M0 60 Q 25 35, 50 60 T 100 60" stroke="rgba(255,255,255,0.2)" fill="none" stroke-width="1"/>
          <path d="M0 70 Q 25 45, 50 70 T 100 70" stroke="rgba(255,255,255,0.1)" fill="none" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#wave-pattern)"/>
    </svg>
  </div>
  
  <!-- Decorative Elements -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-lime-400/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header with Logo and Contact Info -->
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8 mb-16">
      <!-- Convener -->
      <div class="text-center">
        <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-2xl inline-block mb-4">
          <div class="bg-white rounded-2xl p-2">
            <img 
              src={waleAjani.src} 
              alt="Hon. Wale Ajani"
              class="w-48 h-48 object-cover rounded-xl"
            />
          </div>
        </div>
        <h3 class="font-bold text-xl text-white">Hon. Wale Ajani</h3>
        <p class="text-white font-semibold">Convener</p>
      </div>
      
      <!-- Center Logo and Contact -->
      <div class="bg-white rounded-3xl p-8 shadow-2xl text-center max-w-md">
        <div class="mb-4">
          <img 
            src={emergingLogo.src} 
            alt="Emerging Political Leaders Summit Logo" 
            class="h-16 mx-auto mb-4"
          />
          <div class="text-sm text-gray-600 mb-4">Powered by:</div>
          <div class="text-xl font-bold text-emerald-900 mb-4">Close The Gap Initiative</div>
        </div>
        <div class="space-y-2 text-sm text-gray-700">
          <div class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"></path>
            </svg>
            <span>Suite 201Y Novare Central by Spar Wuse Zone 5 Abuja - FCT</span>
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span>eplsummitng@gmail.com</span>
          </div>
          <div class="text-emerald-900 font-medium">www.eplsummit.ng</div>
          <div class="text-orange-600 font-bold text-2xl mt-2">08032266543</div>
        </div>
      </div>
      
      <!-- Project Manager -->
      <div class="text-center">
        <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-2xl inline-block mb-4">
          <div class="bg-white rounded-2xl p-2">
            <img 
              src={mathiasTsado.src} 
              alt="Mr. Mathias Tsado"
              class="w-48 h-48 object-cover rounded-xl"
            />
          </div>
        </div>
        <h3 class="font-bold text-xl text-white">Mr. Mathias Tsado</h3>
        <p class="text-white font-semibold">Project Manager</p>
      </div>
    </div>
    
    <!-- Our Facilitators -->
    <div class="mb-16">
      <h2 class="text-4xl sm:text-5xl font-bold text-white text-center mb-12">
        OUR FACILITATORS
      </h2>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={blessingAkinlosotu.src} alt="Comrade Blessing Akinlosotu" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Comrade Blessing Akinlosotu</h3>
          <p class="text-xs text-white">Executive Director National Civil Council Bureau of Youth</p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={laurettaChinenye.src} alt="Lauretta Chinenye O." class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Lauretta Chinenye O.</h3>
          <p class="text-xs text-white"></p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={otumbaMichael.src} alt="Otumba Michael Husan HON" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Otumba Michael Husan HON</h3>
          <p class="text-xs text-white"></p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={olalade.src} alt="Hon. Olalade John NHI" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Hon. Olalade John NHI</h3>
          <p class="text-xs text-white">Special Adviser on Youth & Student Matters to Kogi state Government</p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={abdullahiAngo.src} alt="Hon. Abdullahi Suleiman Ango" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Hon. Abdullahi Suleiman Ango</h3>
          <p class="text-xs text-white">National Secretary for Agriculture and Rural Development</p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={solaOlofin.src} alt="Hon. Sola Olofin" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Hon. Sola Olofin</h3>
          <p class="text-xs text-white">Chairman NSITF</p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={murtalaAdogi.src} alt="Murtala Adogi Mohammed Ph.D" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Murtala Adogi Mohammed Ph.D</h3>
          <p class="text-xs text-white">Founder/CEO Systems Strategy</p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={ahmedBuhari.src} alt="Ahmed Buhari" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Ahmed Buhari</h3>
          <p class="text-xs text-white"></p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={olamijuwonAlao.src} alt="Hon. Olamijuwon Alao-Akala" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Hon. Olamijuwon Alao-Akala</h3>
          <p class="text-xs text-white">Member House of Reps</p>
        </div>
        
        <div class="text-center">
          <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
            <div class="bg-white rounded-2xl p-2">
              <img src={nafisaAtiku.src} alt="Nafisa Atiku-Abubakar" class="w-full aspect-[3/4] object-cover rounded-xl" />
            </div>
          </div>
          <h3 class="font-bold text-sm text-white mb-1">Nafisa Atiku-Abubakar</h3>
          <p class="text-xs text-white"></p>
        </div>
      </div>
    </div>
    
    <!-- Moderators and Communication Officers -->
    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Moderators -->
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-8">
          MODERATORS
        </h2>
        
        <div class="grid grid-cols-3 gap-6">
          <div class="text-center">
            <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
              <div class="bg-white rounded-2xl p-2">
                <img src={chamberlainUsoh.src} alt="Chamberlain Usoh" class="w-full aspect-[3/4] object-cover rounded-xl" />
              </div>
            </div>
            <h3 class="font-bold text-sm text-white mb-1">Chamberlain Usoh</h3>
            <p class="text-xs text-white">Political Editor, Channels TV</p>
          </div>
          
          <div class="text-center">
            <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
              <div class="bg-white rounded-2xl p-2">
                <img src={seunOkinbaloye.src} alt="Seun Okinbaloye" class="w-full aspect-[3/4] object-cover rounded-xl" />
              </div>
            </div>
            <h3 class="font-bold text-sm text-white mb-1">Seun Okinbaloye</h3>
            <p class="text-xs text-white">Station Manager, Channels TV Abuja</p>
          </div>
          
          <div class="text-center">
            <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
              <div class="bg-white rounded-2xl p-2">
                <img src={adaoraOnyechere.src} alt="Adaora Onyechere" class="w-full aspect-[3/4] object-cover rounded-xl" />
              </div>
            </div>
            <h3 class="font-bold text-sm text-white mb-1">Adaora Onyechere</h3>
            <p class="text-xs text-white">Newscaster AIT</p>
          </div>
        </div>
      </div>
      
      <!-- Communication Officers -->
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-8">
          COMMUNICATION<br />OFFICERS
        </h2>
        
        <div class="grid grid-cols-2 gap-6 max-w-md mx-auto">
          <div class="text-center">
            <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
              <div class="bg-white rounded-2xl p-2">
                <img src={jerryAdesewo.src} alt="Om'Oba Jerry Adesewo" class="w-full aspect-[3/4] object-cover rounded-xl" />
              </div>
            </div>
            <h3 class="font-bold text-sm text-white mb-1">Om'Oba Jerry Adesewo</h3>
            <p class="text-xs text-white"></p>
          </div>
          
          <div class="text-center">
            <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl p-1 shadow-xl mb-3">
              <div class="bg-white rounded-2xl p-2">
                <img src={davidOpeyemi.src} alt="David Opeyemi oke" class="w-full aspect-[3/4] object-cover rounded-xl" />
              </div>
            </div>
            <h3 class="font-bold text-sm text-white mb-1">David Opeyemi oke</h3>
            <p class="text-xs text-white"></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
