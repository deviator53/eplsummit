---
import emergingLogo from '../assets/emerging-logo.png';
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-black/20 backdrop-blur-lg border-b border-white/10 transition-all duration-300">
  <div class="container mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex items-center space-x-3">
        <img src={emergingLogo.src} alt="Emerging Political Leaders Summit" class="h-20 w-auto" />
      </div>
      
      <!-- Desktop Menu -->
      <div class="hidden lg:flex items-center space-x-8">
        <a href="#home" class="text-white hover:text-emerald-800 transition-colors font-medium">Home</a>
        <a href="#about" class="text-white hover:text-emerald-800 transition-colors font-medium">About</a>
        <a href="#conference" class="text-white hover:text-emerald-800 transition-colors font-medium">Conference</a>
        <a href="#events" class="text-white hover:text-emerald-800 transition-colors font-medium">Events</a>
        <a href="#contact" class="text-white hover:text-emerald-800 transition-colors font-medium">Contact</a>
        <button onclick="window.openRegistrationModal()" class="px-6 py-2 bg-emerald-500 text-white font-semibold rounded-lg hover:bg-emerald-600 transition-all duration-300 transform hover:scale-105">
          Register
        </button>
      </div>
      
      <!-- Mobile Menu Button -->
      <button class="lg:hidden text-white p-2" id="mobile-menu-button">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
    
    <!-- Mobile Menu -->
    <div class="lg:hidden hidden" id="mobile-menu">
      <div class="py-4 space-y-4 border-t border-white/10">
        <a href="#home" class="block text-white hover:text-emerald-300 transition-colors font-medium py-2">Home</a>
        <a href="#about" class="block text-emerald-200 hover:text-emerald-300 transition-colors font-medium py-2">About</a>
        <a href="#conference" class="block text-emerald-200 hover:text-emerald-300 transition-colors font-medium py-2">Conference</a>
        <a href="#events" class="block text-emerald-200 hover:text-emerald-300 transition-colors font-medium py-2">Events</a>
        <a href="#contact" class="block text-emerald-200 hover:text-emerald-300 transition-colors font-medium py-2">Contact</a>
        <button onclick="window.openRegistrationModal()" class="w-full mt-4 px-6 py-3 bg-gradient-to-r from-emerald-500 to-teal-500 text-white font-semibold rounded-lg">
          Register
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
      });
    }
  });
</script>