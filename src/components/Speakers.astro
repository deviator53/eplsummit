    title: "National Security Adviser",
    image: ribadu
  },
  {
    name: "Rt. Hon. Abbas Tajudeen, PhD, GCON",
    title: "Speaker, House of Representatives",
    image: abbas,
    highlight: true
  },
  {
    name: "Hon. Olawande Emmanuel Ayodele",
    title: "The Honorable Minister of Youth Development - Chief Host",
    image: olawande,
    highlight: true
  }
];

const speakersAndPanelists = [
  {
    name: "Okanlomo Seyi Tinubu",
    title: "Chief Facilitator",
    image: seyi
  },
  {
    name: "Sen. Hope Uzodinma",
    title: "Chairman, Progressive Governors' Forum",
    image: uzodinma
  },
  {
    name: "Father Matthew Hassan Kukah, CON",
    title: "Founder, The Kukah Center",
    image: matthewHassan
  },
  {
    name: "Mr. Peter Obi",
    title: "Former presidential aspirant, LP",
    image: peterObi
  },
  {
    name: "H.E Gov. Dauda Lawal",
    title: "Zamfara State Governor",
    image: govDauda
  },
  {
    name: "H.E Gov. Nasir Idris",
    title: "Kebbi State Governor",
    image: govNasir
  },
  {
