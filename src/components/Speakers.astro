---

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .speaker-card {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .speaker-card:nth-child(1) { animation-delay: 0.1s; }
  .speaker-card:nth-child(2) { animation-delay: 0.2s; }
  .speaker-card:nth-child(3) { animation-delay: 0.3s; }
  .speaker-card:nth-child(4) { animation-delay: 0.4s; }
  .speaker-card:nth-child(5) { animation-delay: 0.5s; }
  .speaker-card:nth-child(6) { animation-delay: 0.6s; }
  .speaker-card:nth-child(7) { animation-delay: 0.7s; }
  .speaker-card:nth-child(8) { animation-delay: 0.8s; }
  .speaker-card:nth-child(9) { animation-delay: 0.9s; }
  .speaker-card:nth-child(10) { animation-delay: 1s; }
  .speaker-card:nth-child(11) { animation-delay: 1.1s; }
  .speaker-card:nth-child(12) { animation-delay: 1.2s; }
  .speaker-card:nth-child(13) { animation-delay: 1.3s; }
  .speaker-card:nth-child(14) { animation-delay: 1.4s; }
  .speaker-card:nth-child(15) { animation-delay: 1.5s; }
  .speaker-card:nth-child(16) { animation-delay: 1.6s; }
  .speaker-card:nth-child(17) { animation-delay: 1.7s; }
  .speaker-card:nth-child(18) { animation-delay: 1.8s; }
  .speaker-card:nth-child(19) { animation-delay: 1.9s; }
  .speaker-card:nth-child(20) { animation-delay: 2s; }
  .speaker-card:nth-child(21) { animation-delay: 2.1s; }
</style>

<section class="py-16 sm:py-24 bg-gradient-to-br from-emerald-600 via-emerald-700 to-green-800 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-lime-400/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/4 w-64 h-64 bg-emerald-400/10 rounded-full blur-2xl"></div>
  </div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Key Features Section -->
    <div class="mb-16">
      <div class="inline-block bg-white rounded-3xl px-8 py-6 mb-12 shadow-xl">
        <h2 class="text-3xl sm:text-4xl font-bold text-emerald-700">
          KEY <span class="text-emerald-900">FEATURES</span>
        </h2>
      </div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl">
        <div class="flex items-center gap-3 text-white">
          <div class="w-4 h-4 bg-white rounded-full flex-shrink-0"></div>
          <span class="text-lg font-medium">Keynote Speeches</span>
        </div>
        <div class="flex items-center gap-3 text-white">
          <div class="w-4 h-4 bg-white rounded-full flex-shrink-0"></div>
          <span class="text-lg font-medium">Networking and mentorship sessions</span>
        </div>
        <div class="flex items-center gap-3 text-white">
          <div class="w-4 h-4 bg-white rounded-full flex-shrink-0"></div>
          <span class="text-lg font-medium">Plenary and breakout sessions</span>
        </div>
        <div class="flex items-center gap-3 text-white">
          <div class="w-4 h-4 bg-white rounded-full flex-shrink-0"></div>
          <span class="text-lg font-medium">Interactive session (Q&A)</span>
        </div>
        <div class="flex items-center gap-3 text-white">
          <div class="w-4 h-4 bg-white rounded-full flex-shrink-0"></div>
          <span class="text-lg font-medium">Policy hackathons</span>
        </div>
      </div>
    </div>
    
    <!-- Key Speakers Section -->
    <div class="mb-20">
      <div class="inline-block bg-white rounded-3xl px-8 py-6 mb-12 shadow-xl">
        <h2 class="text-3xl sm:text-4xl font-bold text-emerald-700">
          KEY <span class="text-emerald-900">SPEAKERS</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
        {keySpeakers.map((speaker) => (
          <div class="group speaker-card">
            <div class="relative mb-3 sm:mb-6">
              <!-- Lime green frame -->
              <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl sm:rounded-3xl p-1 sm:p-1.5 shadow-xl sm:shadow-2xl transform group-hover:scale-105 transition-transform duration-300">
                <div class="bg-white rounded-2xl sm:rounded-3xl p-1 sm:p-2">
                  <img 
                    src={speaker.image.src} 
                    alt={speaker.name}
                    class="w-full aspect-[3/4] object-cover rounded-xl sm:rounded-2xl"
                  />
                </div>
              </div>
            </div>
            
            <div class="text-center text-white px-1">
              {speaker.badge && (
                <p class="text-xs sm:text-sm italic mb-1 text-lime-300">{speaker.badge}</p>
              )}
              <h3 class="font-bold text-sm sm:text-base lg:text-lg mb-1 sm:mb-2">{speaker.name}</h3>
              <p class="text-xs sm:text-sm text-emerald-100">
                {speaker.highlight && <span class="text-yellow-300">★ </span>}
                {speaker.title}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Speakers and Panelists Section -->
    <div>
      <div class="inline-block bg-white rounded-3xl px-8 py-6 mb-12 shadow-xl">
        <h2 class="text-3xl sm:text-4xl font-bold text-emerald-700">
          SPEAKERS AND <span class="text-emerald-900">PANELISTS</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
        {speakersAndPanelists.map((speaker) => (
          <div class="group speaker-card">
            <div class="relative mb-3 sm:mb-6">
              <!-- Lime green frame -->
              <div class="bg-gradient-to-br from-lime-400 to-lime-500 rounded-2xl sm:rounded-3xl p-1 sm:p-1.5 shadow-xl sm:shadow-2xl transform group-hover:scale-105 transition-transform duration-300">
                <div class="bg-white rounded-2xl sm:rounded-3xl p-1 sm:p-2">
                  <img 
                    src={speaker.image.src} 
                    alt={speaker.name}
                    class="w-full aspect-[3/4] object-cover rounded-xl sm:rounded-2xl"
                  />
                </div>
              </div>
            </div>
            
            <div class="text-center text-white px-1">
              <h3 class="font-bold text-sm sm:text-base lg:text-lg mb-1 sm:mb-2">{speaker.name}</h3>
              <p class="text-xs sm:text-sm text-emerald-100">{speaker.title}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
