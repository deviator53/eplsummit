    title: "Senator representing Kogi Central",
    image: senNatasha
  },
  {
    name: "Rep Mohammed Bello El-Rufai",
    title: "Kaduna North Federal Constituency",
    image: mohammedElrufai
  },
  {
    name: "Dr. Zacch Adelabu Adedeji",
    title: "Chairman, Nigeria Revenue Board",
    image: drZacch
  },
  {
    name: "Dr. Mustapha Abdullahi",
    title: "Director General, Energy Commission of Nigeria",
    image: drMustuapha
  },
  {
    name: "Rt. Hon. Bunmi Tunji-Ojo",
    title: "Hon Minister of Interior",
    image: honBunmi
  },
