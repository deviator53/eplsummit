import olawande from '../assets/olawande.png';
import seyi from '../assets/seyi.png';
import uzodinma from '../assets/uzodinma.png';
import matthewHassan from '../assets/matthew-hassan.png';
import peterObi from '../assets/peter-obi.png';
import govDauda from '../assets/gov-dauda.png';
import govNasir from '../assets/gov-nasir.png';
import senNatasha from '../assets/sen-natasha.png';
import mohammedElrufai from '../assets/mohammed-elrufai.png';
import drZacch from '../assets/dr zacch.png';
