---
// Import all slider images
const sliderImages = import.meta.glob('../assets/sliders/*.{png,jpg,jpeg,webp}', { eager: true });
const imageUrls = Object.values(sliderImages).map((module: any) => module.default);
---

<style>
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: scale(1.1);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .slider-image {
    animation: slideIn 1s ease-in-out;
  }
</style>

<section class="py-16 sm:py-24 bg-gradient-to-br from-gray-50 via-white to-gray-100 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-emerald-200/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-80 h-80 bg-lime-200/30 rounded-full blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-5xl mx-auto">
      <!-- Introduction Text -->
      <div class="mb-12">
        <p class="text-lg sm:text-xl text-gray-700 leading-relaxed mb-6">
          The summit brings together young political aspirants, community leaders, professionals, civil society actors, policymakers, innovators, media, and development partners to foster dialogue, share best practices, and develop actionable strategies for national renewal.
        </p>
        
        <p class="text-lg sm:text-xl text-gray-700 leading-relaxed">
          EPLS is intentionally practical, outcome-driven, youth-centered, and media-visible, blending inspiration with hands-on engagement and post-summit activation. Rather than just dialogue, it will create a pipeline of politically conscious young Nigerians ready to engage responsibly in governance, elections, advocacy, and leadership.
        </p>
      </div>
      
      <!-- Background & Rationale Section -->
      <div class="bg-white rounded-3xl p-8 sm:p-12 shadow-xl border border-gray-100">
        <div class="mb-8">
          <h2 class="text-3xl sm:text-4xl font-bold mb-2">
            <span class="text-emerald-700">BACKGROUND & </span>
            <span class="text-emerald-900">RATIONALE</span>
          </h2>
        </div>
        
        <div class="grid lg:grid-cols-2 gap-8 items-center">
          <!-- Text Content -->
          <div>
            <p class="text-base sm:text-lg text-gray-700 leading-relaxed">
              Nigeria stands at a defining crossroads. With over 60% of the population under 35 years old, the future of the nation's democracy depends largely on the readiness of its youth to participate meaningfully in governance. Yet, political apathy, lack of access, misinformation, and mistrust of institutions continue to hinder young people's engagement.
            </p>
          </div>
          
          <!-- Image Slider -->
          <div class="relative">
            <div class="relative">
              <!-- Green circular accent -->
              <div class="absolute -top-4 -left-4 w-32 h-32 bg-gradient-to-br from-emerald-400 to-emerald-500 rounded-full opacity-20"></div>
              <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-gradient-to-br from-lime-400 to-lime-500 rounded-full opacity-20"></div>
              
              <!-- Image container with green border -->
              <div class="relative bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-3xl p-1.5 shadow-2xl">
                <div class="bg-white rounded-3xl p-2">
                  <div class="aspect-[4/3] rounded-2xl overflow-hidden relative">
                    {imageUrls.map((imageUrl, index) => (
                      <img 
                        src={imageUrl.src}
                        alt={`EPLS Event ${index + 1}`}
                        class={`slider-image absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                        data-slide-index={index}
                      />
                    ))}
                  </div>
                </div>
              </div>
              
              <!-- Slider Indicators -->
              <div class="flex justify-center gap-2 mt-4">
                {imageUrls.map((_, index) => (
                  <button
                    class={`slider-dot w-2 h-2 rounded-full transition-all duration-300 ${index === 0 ? 'bg-emerald-600 w-8' : 'bg-gray-300'}`}
                    data-dot-index={index}
                    aria-label={`Go to slide ${index + 1}`}
                  ></button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.slider-image');
  const dots = document.querySelectorAll('.slider-dot');
  const totalSlides = slides.length;

  function showSlide(index: number) {
    // Hide all slides
    slides.forEach((slide) => {
      slide.classList.remove('opacity-100');
      slide.classList.add('opacity-0');
    });

    // Update dots
    dots.forEach((dot) => {
      dot.classList.remove('bg-emerald-600', 'w-8');
      dot.classList.add('bg-gray-300');
    });

    // Show current slide
    slides[index].classList.remove('opacity-0');
    slides[index].classList.add('opacity-100');

    // Highlight current dot
    dots[index].classList.remove('bg-gray-300');
    dots[index].classList.add('bg-emerald-600', 'w-8');
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % totalSlides;
    showSlide(currentSlide);
  }

  // Auto-advance slides every 4 seconds
  let slideInterval = setInterval(nextSlide, 4000);

  // Add click handlers to dots
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentSlide = index;
      showSlide(currentSlide);
      // Reset interval when manually changing slides
      clearInterval(slideInterval);
      slideInterval = setInterval(nextSlide, 4000);
    });
  });
</script>
