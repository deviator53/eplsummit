---
---

<section id="conference" class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <div class="inline-flex items-center px-4 py-2 bg-emerald-100 rounded-full mb-6">
        <span class="text-emerald-700 text-sm font-medium">The Conference Experience</span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
        Two Days of 
        <span class="bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">
          Transformation
        </span>
      </h2>
      
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        The Emerging Political Leaders Summit is open for young persons, accomplished leaders who contribute to the current context of political discourse and debate, and aspiring leaders who seek to build a prosperous and progressive political system.
      </p>
    </div>
    
    <div class="grid lg:grid-cols-2 gap-16 items-center mb-20">
      <!-- Image Placeholder -->
      <div class="relative">
        <div class="aspect-video bg-gradient-to-br from-emerald-100 to-teal-100 rounded-3xl overflow-hidden shadow-2xl">
          <div class="w-full h-full bg-gradient-to-br from-emerald-400/20 to-teal-400/20 flex items-center justify-center">
            <div class="text-center space-y-4">
              <div class="w-20 h-20 bg-emerald-500 rounded-full flex items-center justify-center mx-auto">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-gray-800">Summit Highlights</h3>
              <p class="text-gray-600">Interactive sessions and networking</p>
            </div>
          </div>
        </div>
        
        <!-- Floating Stats -->
        <div class="absolute -top-6 -right-6 bg-white rounded-2xl p-6 shadow-xl border border-gray-100">
          <div class="text-center">
            <div class="text-3xl font-bold text-emerald-600">500+</div>
            <div class="text-gray-600 text-sm">Participants</div>
          </div>
        </div>
        
       
      </div>
      
      <!-- Content -->
      <div class="space-y-8">
        <div class="space-y-6">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
              <span class="text-emerald-600 font-bold text-lg">1</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Opening Ceremony & Keynotes</h3>
              <p class="text-gray-600">Begin with inspiring keynote speeches from renowned political leaders and thought leaders who will set the tone for transformative discussions.</p>
            </div>
          </div>
          
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center">
              <span class="text-teal-600 font-bold text-lg">2</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Interactive Workshops & Panels</h3>
              <p class="text-gray-600">Engage in hands-on workshops covering policy development, campaign strategies, and effective governance techniques led by industry experts.</p>
            </div>
          </div>
          
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
              <span class="text-emerald-600 font-bold text-lg">3</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Networking & Collaboration</h3>
              <p class="text-gray-600">Connect with peers through structured networking sessions, collaborative projects, and informal meetups that foster lasting professional relationships.</p>
            </div>
          </div>
        </div>
        
        <div class="bg-gradient-to-r from-emerald-50 to-teal-50 rounded-2xl p-8 border border-emerald-100">
          <h4 class="text-lg font-semibold text-gray-900 mb-4">What You'll Gain</h4>
          <ul class="space-y-3">
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700">Advanced leadership and communication skills</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700">Global network of political leaders and changemakers</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700">Practical tools for effective governance and policy-making</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700">Insights into current political trends and future opportunities</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>