---
import eplVideo from '../assets/epl-video.mp4';
---

<section id="conference" class="py-24 bg-gradient-to-br from-emerald-50 via-white to-teal-50 relative overflow-hidden">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-emerald-200/30 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-teal-200/30 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-emerald-300/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <div class="inline-flex items-center px-4 py-2 bg-emerald-100 rounded-full mb-6">
        <span class="text-emerald-700 text-sm font-medium">The Conference Experience</span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
        Two Days of 
        <span class="bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">
          Transformation
        </span>
      </h2>
      
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        The Emerging Political Leaders Summit is open for young persons, accomplished leaders who contribute to the current context of political discourse and debate, and aspiring leaders who seek to build a prosperous and progressive political system.
      </p>
    </div>
    
    <div class="grid lg:grid-cols-2 gap-16 items-center mb-20">
      <!-- Video Player -->
      <div class="relative group">
        <div class="aspect-video bg-gradient-to-br from-emerald-100 to-teal-100 rounded-3xl overflow-hidden shadow-2xl transform transition-all duration-500 hover:scale-[1.02] hover:shadow-emerald-200/50">
          <video 
            class="w-full h-full object-cover"
            autoplay 
            muted 
            loop 
            controls
            playsinline
          >
            <source src={eplVideo} type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        </div>
        
        <!-- Floating Stats with Animation -->
        <div class="absolute -top-6 -right-6 bg-gradient-to-br from-white to-emerald-50 rounded-2xl p-6 shadow-xl border border-emerald-200 transform transition-all duration-300 hover:scale-110 hover:rotate-3">
          <div class="text-center">
            <div class="text-3xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">500+</div>
            <div class="text-gray-600 text-sm font-medium">Participants</div>
          </div>
        </div>
        
        <!-- Additional Floating Badge -->
        <div class="absolute -bottom-6 -left-6 bg-gradient-to-br from-teal-500 to-emerald-600 rounded-2xl p-4 shadow-xl transform transition-all duration-300 hover:scale-110 hover:-rotate-3">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">2 Days</div>
            <div class="text-emerald-50 text-xs font-medium">Of Impact</div>
          </div>
        </div>
      </div>
      
      <!-- Content -->
      <div class="space-y-8">
        <div class="space-y-6">
          <div class="flex items-start space-x-4 group hover:translate-x-2 transition-transform duration-300">
            <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-emerald-100 to-emerald-200 rounded-xl flex items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-110 transition-all duration-300">
              <span class="text-emerald-600 font-bold text-lg">1</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-emerald-600 transition-colors">Opening Ceremony & Keynotes</h3>
              <p class="text-gray-600">Begin with inspiring keynote speeches from renowned political leaders and thought leaders who will set the tone for transformative discussions.</p>
            </div>
          </div>
          
          <div class="flex items-start space-x-4 group hover:translate-x-2 transition-transform duration-300">
            <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-teal-100 to-teal-200 rounded-xl flex items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-110 transition-all duration-300">
              <span class="text-teal-600 font-bold text-lg">2</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-teal-600 transition-colors">Interactive Workshops & Panels</h3>
              <p class="text-gray-600">Engage in hands-on workshops covering policy development, campaign strategies, and effective governance techniques led by industry experts.</p>
            </div>
          </div>
          
          <div class="flex items-start space-x-4 group hover:translate-x-2 transition-transform duration-300">
            <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-emerald-100 to-emerald-200 rounded-xl flex items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-110 transition-all duration-300">
              <span class="text-emerald-600 font-bold text-lg">3</span>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-emerald-600 transition-colors">Networking & Collaboration</h3>
              <p class="text-gray-600">Connect with peers through structured networking sessions, collaborative projects, and informal meetups that foster lasting professional relationships.</p>
            </div>
          </div>
        </div>
        
        <div class="bg-gradient-to-r from-emerald-50 to-teal-50 rounded-2xl p-8 border border-emerald-100">
          <h4 class="text-lg font-semibold text-gray-900 mb-4">What You'll Gain</h4>
          <ul class="space-y-3">
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700">Advanced leadership and communication skills</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700">Global network of political leaders and changemakers</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700">Practical tools for effective governance and policy-making</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700">Insights into current political trends and future opportunities</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>