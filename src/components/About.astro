---
import conversationEpl from '../assets/conversation-epl.jpg';
import dialogueEpl from '../assets/dialogue-epl.jpg';
import growthEpl from '../assets/growth-epl.jpg';
import leadershipEpl from '../assets/leadership-epl.jpg';
---

<section id="about" class="py-24 bg-gradient-to-b from-gray-50 to-white">
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div class="space-y-8">
        <div class="space-y-4">
          <div class="inline-flex items-center px-4 py-2 bg-emerald-100 rounded-full">
            <span class="text-emerald-700 text-sm font-medium">About the Summit</span>
          </div>
          
          <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 leading-tight">
            Empowering the 
            <span class="text-emerald-600">
              Next Generation
            </span>
            of Leaders
          </h2>
          
          <p class="text-xl text-gray-600 leading-relaxed">
            The Emerging Political Leaders Summit brings together visionary minds from across the globe to foster innovative solutions, build meaningful connections, and shape the future of governance.
          </p>
        </div>
        
        <div class="space-y-6">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Innovation-Driven Discussions</h3>
              <p class="text-gray-600">Engage in cutting-edge conversations that challenge conventional thinking and inspire breakthrough solutions.</p>
            </div>
          </div>
          
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Global Network Building</h3>
              <p class="text-gray-600">Connect with like-minded leaders from diverse backgrounds and create lasting partnerships that transcend borders.</p>
            </div>
          </div>
          
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Transformative Learning</h3>
              <p class="text-gray-600">Participate in workshops and sessions designed to enhance leadership skills and political acumen.</p>
            </div>
          </div>
        </div>
        
        <div class="pt-8">
          <button class="group px-8 py-4 bg-gradient-to-r from-emerald-600 to-teal-600 text-white font-semibold rounded-xl hover:from-emerald-700 hover:to-teal-700 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-emerald-500/25">
            <span class="flex items-center gap-2">
              Discover More
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </button>
        </div>
      </div>
      
      <!-- Visual -->
      <div class="relative">
        <div class="relative z-10 bg-gradient-to-br from-emerald-50 to-teal-50 rounded-3xl p-8 shadow-2xl">
          <div class="relative overflow-hidden">
            <!-- Carousel Container -->
            <div class="carousel-container">
              <div class="carousel-track flex gap-6 transition-transform duration-500 ease-in-out">
                <!-- Card 1: Leadership -->
                <div class="carousel-card flex-shrink-0 w-full bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 relative h-96">
                  <img src={leadershipEpl.src} alt="Leadership" class="absolute inset-0 w-full h-full object-cover" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
                    <div class="w-12 h-12 bg-emerald-500/90 rounded-xl flex items-center justify-center mb-4">
                      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                      </svg>
                    </div>
                    <h4 class="font-bold text-2xl mb-3">Leadership</h4>
                    <p class="text-gray-200">Develop essential leadership skills to inspire and guide your community toward positive change.</p>
                  </div>
                </div>

                <!-- Card 2: Dialogue -->
                <div class="carousel-card flex-shrink-0 w-full bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 relative h-96">
                  <img src={dialogueEpl.src} alt="Dialogue" class="absolute inset-0 w-full h-full object-cover" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
                    <div class="w-12 h-12 bg-teal-500/90 rounded-xl flex items-center justify-center mb-4">
                      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                      </svg>
                    </div>
                    <h4 class="font-bold text-2xl mb-3">Dialogue</h4>
                    <p class="text-gray-200">Engage in meaningful conversations that bridge divides and foster understanding across perspectives.</p>
                  </div>
                </div>

                <!-- Card 3: Growth -->
                <div class="carousel-card flex-shrink-0 w-full bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 relative h-96">
                  <img src={growthEpl.src} alt="Growth" class="absolute inset-0 w-full h-full object-cover" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
                    <div class="w-12 h-12 bg-emerald-500/90 rounded-xl flex items-center justify-center mb-4">
                      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                      </svg>
                    </div>
                    <h4 class="font-bold text-2xl mb-3">Growth</h4>
                    <p class="text-gray-200">Experience personal and professional development through workshops and mentorship opportunities.</p>
                  </div>
                </div>

                <!-- Card 4: Conversation -->
                <div class="carousel-card flex-shrink-0 w-full bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 relative h-96">
                  <img src={conversationEpl.src} alt="Conversation" class="absolute inset-0 w-full h-full object-cover" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
                    <div class="w-12 h-12 bg-teal-500/90 rounded-xl flex items-center justify-center mb-4">
                      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                    </div>
                    <h4 class="font-bold text-2xl mb-3">Global Impact</h4>
                    <p class="text-gray-200">Create worldwide change by connecting with leaders from diverse backgrounds and cultures.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Navigation Buttons -->
            <button id="prevBtn" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-emerald-50 transition-colors z-10">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
            </button>
            <button id="nextBtn" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-emerald-50 transition-colors z-10">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>

            <!-- Dots Indicator -->
            <div class="flex justify-center gap-2 mt-6">
              <button class="carousel-dot w-3 h-3 rounded-full bg-emerald-600 transition-all" data-index="0"></button>
              <button class="carousel-dot w-3 h-3 rounded-full bg-gray-300 transition-all" data-index="1"></button>
              <button class="carousel-dot w-3 h-3 rounded-full bg-gray-300 transition-all" data-index="2"></button>
              <button class="carousel-dot w-3 h-3 rounded-full bg-gray-300 transition-all" data-index="3"></button>
            </div>
          </div>
        </div>
        
        <!-- Background Elements -->
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-emerald-200 rounded-full opacity-50"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-teal-200 rounded-full opacity-30"></div>
      </div>
    </div>
  </div>
</section>

<script>
  let currentIndex = 0;
  const track = document.querySelector('.carousel-track') as HTMLElement;
  const cards = document.querySelectorAll('.carousel-card');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const totalCards = cards.length;

  function updateCarousel() {
    if (track) {
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
    }
    
    dots.forEach((dot, index) => {
      if (index === currentIndex) {
        dot.classList.remove('bg-gray-300');
        dot.classList.add('bg-emerald-600');
      } else {
        dot.classList.remove('bg-emerald-600');
        dot.classList.add('bg-gray-300');
      }
    });
  }

  function nextSlide() {
    currentIndex = (currentIndex + 1) % totalCards;
    updateCarousel();
  }

  function prevSlide() {
    currentIndex = (currentIndex - 1 + totalCards) % totalCards;
    updateCarousel();
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', nextSlide);
  }
  
  if (prevBtn) {
    prevBtn.addEventListener('click', prevSlide);
  }

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel();
    });
  });

  setInterval(nextSlide, 5000);
</script>
