---
---

<section id="events" class="py-24 bg-gradient-to-b from-white to-gray-50">
  <div class="container mx-auto px-6">
    <!-- Past Events Section -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center px-4 py-2 bg-gray-100 rounded-full mb-6">
        <span class="text-gray-700 text-sm font-medium">Past Events</span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
        Previous Summit 
        <span class="bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">
          Editions
        </span>
      </h2>
      
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Explore our successful regional summits that brought together emerging leaders across different locations.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
      <!-- Kogi Edition -->
      <div class="group relative bg-gradient-to-br from-gray-500 to-gray-600 rounded-3xl p-8 text-white overflow-hidden hover:scale-105 transition-all duration-300 shadow-2xl">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute inset-0 bg-white/5"></div>
        </div>
        
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-white/10 rounded-full blur-xl"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-white/5 rounded-full blur-xl"></div>
        
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <div class="bg-white/20 backdrop-blur-sm rounded-xl px-4 py-2">
              <span class="text-sm font-medium">KOGI 2019</span>
            </div>
            <div class="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
          </div>
          
          <h3 class="text-3xl font-bold mb-4">KOGI EDITION</h3>
          
          <div class="space-y-4 mb-8">
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <span class="text-gray-100">6th August, 2019</span>
            </div>
            
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-gray-100">9:00am</span>
            </div>
            
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span class="text-gray-100">Riverton Hotel, Lokoja</span>
            </div>
          </div>
          
          <p class="text-gray-100 mb-8 leading-relaxed">
            Focusing on grassroots leadership and community engagement, this edition explored how local governance can drive national transformation.
          </p>
          
          <button class="w-full bg-white text-gray-600 font-semibold py-4 rounded-xl hover:bg-gray-50 transition-colors">
            View Highlights
          </button>
        </div>
      </div>
      
      <!-- Bayelsa Edition -->
      <div class="group relative bg-gradient-to-br from-gray-500 to-gray-600 rounded-3xl p-8 text-white overflow-hidden hover:scale-105 transition-all duration-300 shadow-2xl">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute inset-0 bg-white/5"></div>
        </div>
        
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-white/10 rounded-full blur-xl"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-white/5 rounded-full blur-xl"></div>
        
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <div class="bg-white/20 backdrop-blur-sm rounded-xl px-4 py-2">
              <span class="text-sm font-medium">BAYELSA 2019</span>
            </div>
            <div class="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
          </div>
          
          <h3 class="text-3xl font-bold mb-4">BAYELSA EDITION</h3>
          
          <div class="space-y-4 mb-8">
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <span class="text-gray-100">8th August, 2019</span>
            </div>
            
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-gray-100">9:00am</span>
            </div>
            
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span class="text-gray-100">Ayelis Hotels, Yenagoa</span>
            </div>
          </div>
          
          <p class="text-gray-100 mb-8 leading-relaxed">
            Emphasizing environmental leadership and sustainable development, this edition addressed the unique challenges of resource-rich regions.
          </p>
          
          <button class="w-full bg-white text-gray-600 font-semibold py-4 rounded-xl hover:bg-gray-50 transition-colors">
            View Highlights
          </button>
        </div>
      </div>
    </div>
    
    <!-- Upcoming Events Teaser -->
    <div class="text-center mt-16">
      <div class="bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-3xl p-12 text-white shadow-2xl">
        <div class="inline-flex items-center px-4 py-2 bg-white/20 backdrop-blur-sm rounded-full mb-6">
          <span class="text-white text-sm font-medium">Coming Soon</span>
        </div>
        <h3 class="text-3xl font-bold mb-6">Abuja 2026 Edition</h3>
        <p class="text-xl text-emerald-100 mb-8 max-w-2xl mx-auto">
          Join us for the biggest gathering of emerging political leaders. Network with visionaries, learn from experts, and shape Nigeria's future.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <button onclick="openRegistrationModal()" class="px-8 py-4 bg-white text-emerald-600 font-semibold rounded-xl hover:bg-emerald-50 transform hover:scale-105 transition-all duration-300 shadow-lg">
            Register Now
          </button>
          <button class="px-8 py-4 border-2 border-white text-white font-semibold rounded-xl hover:bg-white/10 transition-all duration-300">
            Learn More
          </button>
        </div>
      </div>
    </div>
  </div>
</section>