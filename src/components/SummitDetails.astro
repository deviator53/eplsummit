---
import emergingLogo from '../assets/emerging-logo.png';
---

<section class="py-16 sm:py-24 bg-gradient-to-br from-emerald-600 via-emerald-700 to-green-800 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.1) 35px, rgba(255,255,255,.1) 70px);"></div>
  </div>
  
  <!-- Decorative Elements -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-lime-400/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Logo -->
      <div class="mb-8">
        <img 
          src={emergingLogo.src} 
          alt="Emerging Political Leaders Summit Logo" 
          class="h-16 sm:h-20 mx-auto"
        />
      </div>
      
      <!-- Main Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-4 leading-tight">
        EMERGING POLITICAL<br />
        LEADERS SUMMIT 2026
      </h1>
      
      <!-- Edition Badge -->
      <div class="inline-block bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-2 rounded-lg mb-8">
        <span class="text-white font-bold text-lg sm:text-xl">4TH EDITION</span>
      </div>
      
      <!-- Theme -->
      <div class="mb-8">
        <p class="text-lime-300 text-xl sm:text-2xl font-light italic mb-4">Theme:</p>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-2">
          FORWARD TOGETHER: PREPARING EMERGING
        </h2>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4">
          <span class="bg-lime-400 text-emerald-900 px-4 py-1">LEADERS FOR 2027 ELECTIONS</span>
        </h2>
        <p class="text-lime-300 text-lg sm:text-xl italic">Building Trust, Driving Progress..</p>
      </div>
      
      <!-- Date -->
      <div class="mb-12">
        <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm px-8 py-4 rounded-xl border border-white/20">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="text-white text-xl sm:text-2xl font-bold">24TH & 25TH MARCH 2026</span>
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
      </div>
      
      <!-- Subtitle -->
      <div class="mb-8">
        <h3 class="text-3xl sm:text-4xl font-bold text-white mb-3">
          BUILDING A NEW NIGERIA
        </h3>
        <div class="inline-block bg-gradient-to-r from-blue-900 to-blue-800 px-6 py-2 rounded-lg">
          <p class="text-yellow-400 text-base sm:text-lg font-semibold">
            Youth, Leadership, Governance & the Road to 2027
          </p>
        </div>
      </div>
      
      <!-- Location -->
      <div class="flex items-center justify-center gap-3 text-white">
        <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"></path>
        </svg>
        <p class="text-base sm:text-lg">
          <span class="font-semibold">Rotunda Hall, Ministry of Foreign Affairs, Central Business District, Abuja</span>
        </p>
      </div>
      
      <!-- CTA Button -->
      <div class="mt-12">
        <button onclick="openRegistrationModal()" class="px-10 py-5 bg-white text-emerald-700 font-bold text-lg rounded-xl hover:bg-emerald-50 transform hover:scale-105 transition-all duration-300 shadow-2xl">
          Register for Summit 2026
        </button>
      </div>
    </div>
  </div>
</section>
