---
---

<section class="py-16 sm:py-24 bg-gradient-to-br from-gray-100 to-gray-200 relative overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Expected Outcomes Section -->
    <div class="mb-20">
      <h2 class="text-4xl sm:text-5xl font-bold text-emerald-700 mb-12">
        EXPECTED <span class="text-emerald-900">OUTCOMES</span>
      </h2>
      
      <div class="grid sm:grid-cols-2 gap-6 max-w-5xl">
        <div class="flex items-start gap-4 bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-8 h-8 bg-emerald-700 rounded-full flex-shrink-0 mt-1"></div>
          <div>
            <p class="text-lg text-gray-800 font-medium">Summit Communiqué with actionable recommendations.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-8 h-8 bg-emerald-700 rounded-full flex-shrink-0 mt-1"></div>
          <div>
            <p class="text-lg text-gray-800 font-medium">Creation of Emerging Political Leaders Ambassador Network.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-8 h-8 bg-emerald-700 rounded-full flex-shrink-0 mt-1"></div>
          <div>
            <p class="text-lg text-gray-800 font-medium">Policy briefs and white papers on key thematic areas.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-8 h-8 bg-emerald-700 rounded-full flex-shrink-0 mt-1"></div>
          <div>
            <p class="text-lg text-gray-800 font-medium">Action plans for youth and women inclusion in 2027 elections.</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Partnerships and Stakeholders Section -->
    <div>
      <h2 class="text-4xl sm:text-5xl font-bold text-emerald-700 mb-12">
        PARTNERSHIPS AND <span class="text-emerald-900">STAKEHOLDERS</span>
      </h2>
      
      <div class="space-y-4 max-w-5xl">
        <!-- Government Agencies -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="bg-emerald-700 text-white px-8 py-6 font-bold text-lg sm:min-w-[280px] w-full sm:w-auto">
            Government Agencies
          </div>
          <div class="px-8 py-6 text-gray-800 text-lg">
            INEC, Ministry of Youth, Ministry of Women Affairs
          </div>
        </div>
        
        <!-- Political Parties -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="bg-emerald-700 text-white px-8 py-6 font-bold text-lg sm:min-w-[280px] w-full sm:w-auto">
            Political Parties
          </div>
          <div class="px-8 py-6 text-gray-800 text-lg">
            All Political Parties in Nigeria
          </div>
        </div>
        
        <!-- Development Partners -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="bg-emerald-700 text-white px-8 py-6 font-bold text-lg sm:min-w-[280px] w-full sm:w-auto">
            Development Partners
          </div>
          <div class="px-8 py-6 text-gray-800 text-lg">
            UNDP, EU, USAID, Commonwealth, AU
          </div>
        </div>
        
        <!-- The Diplomatic Community -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="bg-emerald-700 text-white px-8 py-6 font-bold text-lg sm:min-w-[280px] w-full sm:w-auto">
            The Diplomatic Community
          </div>
          <div class="px-8 py-6 text-gray-800 text-lg">
            U.S Consulate, British High Commission
          </div>
        </div>
        
        <!-- Civil Society Organizations -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="bg-emerald-700 text-white px-8 py-6 font-bold text-lg sm:min-w-[280px] w-full sm:w-auto">
            Civil Society Organizations
          </div>
          <div class="px-8 py-6 text-gray-800 text-lg">
            YIAGA Africa, CODE
          </div>
        </div>
        
        <!-- Media Organizations -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="bg-emerald-700 text-white px-8 py-6 font-bold text-lg sm:min-w-[280px] w-full sm:w-auto">
            Media Organizations
          </div>
          <div class="px-8 py-6 text-gray-800 text-lg">
            Legit.NG, Major Newspapers, TV Stations, Radio stations
          </div>
        </div>
        
        <!-- Influencers -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="bg-emerald-700 text-white px-8 py-6 font-bold text-lg sm:min-w-[280px] w-full sm:w-auto">
            Influencers:
          </div>
          <div class="px-8 py-6 text-gray-800 text-lg">
            Real Warri Pikin, Governor Amuneke
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
