---
import Navigation from './Navigation.astro';
import eplBanner from '../assets/epl-banner.png';
import emergingImage from '../assets/emerging.png';
---

<section class="relative min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-emerald-900 overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <img 
      src={eplBanner.src} 
      alt="EPL Summit Banner" 
      class="w-full h-full object-cover opacity-30"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900/80 via-slate-800/70 to-emerald-900/80"></div>
  </div>
  
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-teal-500/10 rounded-full blur-3xl animate-pulse delay-1000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-emerald-400/5 rounded-full blur-2xl animate-pulse delay-500"></div>
  </div>
  
  <Navigation />
  
  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 pt-24 sm:pt-32 pb-16 sm:pb-20">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center min-h-[calc(100vh-8rem)]">
      <!-- Content -->
      <div class="lg:col-span-7 space-y-6 sm:space-y-8 animate-fade-in-up">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/20 backdrop-blur-sm rounded-full border border-emerald-400/30 shadow-lg">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
          <span class="text-emerald-100 text-sm font-medium">Empowering Future Leaders</span>
        </div>
        
        <!-- Main Heading -->
        <div class="space-y-4">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-tight">
            <span class="block text-emerald-400 mb-2">Emerging</span>
            <span class="block text-white mb-2">Political Leaders</span>
            <span class="block text-emerald-400">Summit</span>
          </h1>
          
          <p class="text-lg sm:text-xl text-slate-300 leading-relaxed max-w-2xl">
            Join the most influential gathering of emerging political leaders. Connect, learn, and shape the future of governance through innovative discussions and transformative networking.
          </p>
        </div>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <button onclick="openRegistrationModal()" class="group relative px-8 py-4 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-xl transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-emerald-500/25 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900">
            <span class="flex items-center justify-center gap-2">
              Register Now
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </button>
          
          <button class="px-8 py-4 border-2 border-emerald-500 text-emerald-400 hover:text-white font-semibold rounded-xl hover:bg-emerald-500 transition-all duration-300 backdrop-blur-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900">
            Learn More
          </button>
        </div>
        
        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 sm:gap-8 pt-8 border-t border-slate-700/50">
          <div class="text-center group">
            <div class="text-2xl sm:text-3xl font-bold text-white group-hover:text-emerald-400 transition-colors">500+</div>
            <div class="text-slate-400 text-sm font-medium">Leaders</div>
          </div>
          <div class="text-center group">
            <div class="text-2xl sm:text-3xl font-bold text-white group-hover:text-emerald-400 transition-colors">20+</div>
            <div class="text-slate-400 text-sm font-medium">States</div>
          </div>
          <div class="text-center group">
            <div class="text-2xl sm:text-3xl font-bold text-white group-hover:text-emerald-400 transition-colors">2</div>
            <div class="text-slate-400 text-sm font-medium">Days</div>
          </div>
        </div>
      </div>
      
      <!-- Visual Element -->
      <div class="lg:col-span-5 relative animate-fade-in-right">
        <!-- Main Visual Card -->
        <div class="relative bg-gradient-to-br from-white/10 to-white/5 backdrop-blur-lg rounded-3xl p-6 sm:p-8 border border-white/20 shadow-2xl">
          <div class="aspect-square bg-gradient-to-br from-emerald-500/20 to-teal-500/20 rounded-2xl flex items-center justify-center relative overflow-hidden">
            <!-- Emerging Image -->
            <div class="relative z-10 w-full h-full flex items-center justify-center">
              <img 
                src={emergingImage.src} 
                alt="Emerging Political Leaders" 
                class="w-full h-full object-cover rounded-2xl opacity-90 hover:opacity-100 transition-opacity duration-300"
              />
              <!-- Overlay with text -->
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent rounded-2xl flex items-end justify-center p-6">
                <div class="text-center">
                  <h3 class="text-lg sm:text-xl font-semibold text-white mb-2">Global Network</h3>
                  <p class="text-emerald-200 text-sm">Connect with leaders worldwide</p>
                </div>
              </div>
            </div>
            
            <!-- Background Pattern -->
            <div class="absolute inset-0 opacity-10 rounded-2xl">
              <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, rgba(16, 185, 129, 0.1) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(20, 184, 166, 0.1) 0%, transparent 50%);"></div>
            </div>
          </div>
        </div>
        
        <!-- Floating Feature Cards -->
        <div class="absolute -top-4 -right-4 bg-emerald-600 rounded-2xl p-4 shadow-xl animate-float border border-emerald-500/50">
          <div class="text-white text-sm font-semibold">Live Sessions</div>
          <div class="text-emerald-100 text-xs">Interactive workshops</div>
        </div>
        
        <div class="absolute -bottom-4 -left-4 bg-teal-600 rounded-2xl p-4 shadow-xl animate-float-delayed border border-teal-500/50">
          <div class="text-white text-sm font-semibold">Networking</div>
          <div class="text-teal-100 text-xs">Build connections</div>
        </div>
        
        <div class="absolute top-1/2 -left-8 bg-slate-800/90 backdrop-blur-sm rounded-xl p-3 shadow-lg animate-float border border-slate-700">
          <div class="text-emerald-400 text-xs font-medium">March 2026</div>
          <div class="text-white text-xs">Save the date</div>
        </div>
      </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-emerald-400/50 rounded-full flex justify-center">
        <div class="w-1 h-3 bg-emerald-400 rounded-full mt-2 animate-pulse"></div>
      </div>
    </div>
  </div>
</section>

