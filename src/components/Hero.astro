---
import Navigation from './Navigation.astro';
import eplSummit1 from '../assets/epl-summit1.jpg';
import eplSummit2 from '../assets/epl-summit2.jpg';
import eplSummit3 from '../assets/epl-summit3.jpg';
import eplSummit4 from '../assets/epl-summit4.jpg';
import eplSummit5 from '../assets/epl-summit5.jpg';
import eplSummit6 from '../assets/epl-summit6.jpg';
import eplSummit7 from '../assets/epl-summit7.jpg';
import eplSummit8 from '../assets/epl-summit8.jpg';
import eplSummit9 from '../assets/epl-summit9.jpg';
---

<section class="relative min-h-screen overflow-hidden bg-slate-900">
  <!-- Sliding Background Images -->
  <div class="slideshow">
    <div class="slide active">
      <img src={eplSummit1.src} alt="EPL Summit" />
    </div>
    <div class="slide">
      <img src={eplSummit2.src} alt="EPL Summit" />
    </div>
    <div class="slide">
      <img src={eplSummit3.src} alt="EPL Summit" />
    </div>
    <div class="slide">
      <img src={eplSummit4.src} alt="EPL Summit" />
    </div>
    <div class="slide">
      <img src={eplSummit5.src} alt="EPL Summit" />
    </div>
    <div class="slide">
      <img src={eplSummit6.src} alt="EPL Summit" />
    </div>
    <div class="slide">
      <img src={eplSummit7.src} alt="EPL Summit" />
    </div>
    <div class="slide">
      <img src={eplSummit8.src} alt="EPL Summit" />
    </div>
    <div class="slide">
      <img src={eplSummit9.src} alt="EPL Summit" />
    </div>
  </div>
  
  <!-- Light Overlay for Text Readability -->
  <div class="absolute inset-0 z-10 bg-gradient-to-br from-slate-950/40 via-slate-900/30 to-emerald-950/40"></div>
  
  <div class="relative z-20">
    <Navigation />
  </div>
  
  <div class="relative z-30 container mx-auto px-4 sm:px-6 lg:px-8 pt-32 sm:pt-40 pb-16 sm:pb-20">
    <div class="max-w-6xl mx-auto text-center min-h-[calc(100vh-12rem)] flex flex-col justify-center">
      <!-- Modern Badge with Glow Effect -->
      <div class="inline-flex items-center gap-2 px-6 py-1 bg-gradient-to-r from-emerald-500/20 to-teal-500/20 backdrop-blur-xl rounded-full border border-emerald-400/40 shadow-2xl shadow-emerald-500/20 mb-2 mx-auto animate-fade-in-up">
        <div class="relative">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
          <div class="absolute inset-0 w-2 h-2 bg-emerald-400 rounded-full animate-ping"></div>
        </div>
        <span class="text-emerald-100 text-sm sm:text-base font-semibold tracking-wide">Empowering Future Leaders</span>
      </div>
      
      <!-- Main Heading with Modern Typography -->
      <div class="space-y-6 mb-10 animate-fade-in-up" style="animation-delay: 0.2s;">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-extrabold leading-tight tracking-tight" style="font-family: 'Nunito', sans-serif;">
          <span class="block text-emerald-600 mb-1 drop-shadow-2xl">EMERGING</span>
          <span class="block text-white mb-3 drop-shadow-2xl text-uppercase">POLITICAL LEADERS</span>
          <span class="block text-emerald-600 drop-shadow-2xl text-uppercase">SUMMIT 2026</span>
        </h1>
        
        <p class="text-xl sm:text-2xl lg:text-3xl text-slate-200 leading-relaxed max-w-4xl mx-auto font-light drop-shadow-lg">
          Join the most influential gathering of emerging political leaders. Connect, learn, and shape the future of governance.
        </p>
      </div>
      
      <!-- Modern CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-5 justify-center pt-8 animate-fade-in-up" style="animation-delay: 0.4s;">
        <button onclick="openRegistrationModal()" class="group relative px-12 py-5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-500 hover:to-teal-500 text-white font-bold text-lg rounded-2xl transform hover:scale-105 transition-all duration-300 shadow-2xl shadow-emerald-500/50 hover:shadow-emerald-400/60 focus:outline-none focus:ring-4 focus:ring-emerald-500/50 overflow-hidden">
          <span class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/20 to-white/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></span>
          <span class="relative flex items-center justify-center gap-3">
            Register Now
            <svg class="w-6 h-6 group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </button>
        
        <button class="px-12 py-5 border-2 border-emerald-400/60 text-emerald-300 hover:text-white font-bold text-lg rounded-2xl hover:bg-emerald-500/20 hover:border-emerald-400 transition-all duration-300 backdrop-blur-xl focus:outline-none focus:ring-4 focus:ring-emerald-500/50 shadow-xl hover:shadow-2xl transform hover:scale-105">
          Learn More
        </button>
      </div>
      
      <!-- Modern Stats with Cards -->
      <div class="grid grid-cols-3 gap-6 sm:gap-8 pt-20 mt-20 max-w-4xl mx-auto animate-fade-in-up" style="animation-delay: 0.6s; font-family: 'Nunito', sans-serif;">
        <div class="group relative bg-gradient-to-br from-slate-800/60 to-slate-900/60 backdrop-blur-xl rounded-2xl p-6 border border-emerald-500/20 hover:border-emerald-400/50 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-emerald-500/20">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/0 to-emerald-500/10 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="text-4xl sm:text-5xl lg:text-6xl font-extrabold bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent mb-2">500+</div>
            <div class="text-slate-300 text-sm sm:text-base font-semibold tracking-wide">Leaders</div>
          </div>
        </div>
        <div class="group relative bg-gradient-to-br from-slate-800/60 to-slate-900/60 backdrop-blur-xl rounded-2xl p-6 border border-emerald-500/20 hover:border-emerald-400/50 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-emerald-500/20">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/0 to-emerald-500/10 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="text-4xl sm:text-5xl lg:text-6xl font-extrabold bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent mb-2">20+</div>
            <div class="text-slate-300 text-sm sm:text-base font-semibold tracking-wide">States</div>
          </div>
        </div>
        <div class="group relative bg-gradient-to-br from-slate-800/60 to-slate-900/60 backdrop-blur-xl rounded-2xl p-6 border border-emerald-500/20 hover:border-emerald-400/50 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-emerald-500/20">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/0 to-emerald-500/10 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="text-4xl sm:text-5xl lg:text-6xl font-extrabold bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent mb-2">2</div>
            <div class="text-slate-300 text-sm sm:text-base font-semibold tracking-wide">Days</div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Modern Scroll Indicator -->
   
  </div>
</section>

<style>
  .slideshow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  
  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 2s ease-in-out;
  }
  
  .slide.active {
    opacity: 1 !important;
  }
  
  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: kenburns 20s ease-in-out infinite;
  }
  
  @keyframes kenburns {
    0% {
      transform: scale(1) translateX(0);
    }
    50% {
      transform: scale(1.15) translateX(-20px);
    }
    100% {
      transform: scale(1) translateX(0);
    }
  }
  
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-up {
    animation: fade-in-up 1s ease-out forwards;
    opacity: 0;
  }
</style>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.slide');
  const totalSlides = slides.length;
  
  function showSlide(index: number) {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.add('active');
      } else {
        slide.classList.remove('active');
      }
    });
  }
  
  function nextSlide() {
    currentSlide = (currentSlide + 1) % totalSlides;
    showSlide(currentSlide);
  }
  
  // Change slide every 5 seconds
  setInterval(nextSlide, 5000);
</script>
