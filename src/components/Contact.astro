---
import emergingLogo from '../assets/emerging-logo1.png';
---

<section id="contact" class="py-24 bg-gradient-to-br from-emerald-50 via-white to-gray-50 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: repeating-radial-gradient(circle at 0 0, transparent 0, rgba(16,185,129,0.1) 2px, transparent 2px);"></div>
  </div>
  
  <!-- Floating Elements -->
  <div class="absolute top-20 left-10 w-32 h-32 bg-emerald-200/30 rounded-full blur-xl animate-pulse"></div>
  <div class="absolute bottom-20 right-10 w-48 h-48 bg-lime-200/30 rounded-full blur-xl animate-pulse delay-1000"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <div class="inline-flex items-center px-4 py-2 bg-emerald-100 rounded-full mb-6">
        <span class="text-emerald-700 text-sm font-medium">Get In Touch</span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
        Ready to 
        <span class="bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">
          Connect?
        </span>
      </h2>
      
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Join our community of emerging leaders or get in touch to learn more about upcoming summits and opportunities.
      </p>
    </div>
    
    <div class="grid lg:grid-cols-2 gap-16 max-w-6xl mx-auto">
      <!-- Contact Form -->
      <div class="bg-white rounded-3xl p-8 shadow-2xl border border-gray-100">
        <h3 class="text-2xl font-bold text-gray-900 mb-8">Send us a Message</h3>
        
        <!-- Success Message -->
        <div id="contactSuccessMessage" class="hidden mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-emerald-800 font-medium">Thank you! Your message has been sent successfully.</p>
          </div>
        </div>
        
        <!-- Error Message -->
        <div id="contactErrorMessage" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-red-800 font-medium">Oops! Something went wrong. Please try again.</p>
          </div>
        </div>
        
        <form id="contactForm" action="https://formspree.io/f/mvzwapez" method="POST" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-gray-700 text-sm font-medium mb-2">First Name</label>
              <input type="text" name="firstName" required class="w-full px-4 py-3 bg-white border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="John">
            </div>
            <div>
              <label class="block text-gray-700 text-sm font-medium mb-2">Last Name</label>
              <input type="text" name="lastName" required class="w-full px-4 py-3 bg-white border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="Doe">
            </div>
          </div>
          
          <div>
            <label class="block text-gray-700 text-sm font-medium mb-2">Email</label>
            <input type="email" name="email" required class="w-full px-4 py-3 bg-white border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="john@example.com">
          </div>
          
          <div>
            <label class="block text-gray-700 text-sm font-medium mb-2">Subject</label>
            <select name="subject" required class="w-full px-4 py-3 bg-white border border-gray-300 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent">
              <option value="">Select a topic</option>
              <option value="registration">Event Registration</option>
              <option value="partnership">Partnership Opportunities</option>
              <option value="speaking">Speaking Opportunities</option>
              <option value="general">General Inquiry</option>
            </select>
          </div>
          
          <div>
            <label class="block text-gray-700 text-sm font-medium mb-2">Message</label>
            <textarea rows="5" name="message" required class="w-full px-4 py-3 bg-white border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none" placeholder="Tell us about your interest in the summit..."></textarea>
          </div>
          
          <button type="submit" id="contactSubmitBtn" class="w-full px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-500 text-white font-semibold rounded-xl hover:from-emerald-600 hover:to-teal-600 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-emerald-500/25">
            Send Message
          </button>
        </form>
      </div>
      
      <!-- Contact Information -->
      <div class="space-y-8">
        <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-xl">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Get in Touch</h3>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900 mb-1">Email</h4>
                <p class="text-gray-600">info@eplsummit.ng</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900 mb-1">Phone</h4>
                <p class="text-gray-600">+234-80-322-665-43</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900 mb-1">Office</h4>
                <p class="text-gray-600">Suite C14 Amsalco Plaza, Dunukofia Street by FCDA, Area 11, Garki</p>
                <p class="text-gray-600">Abuja, Nigeria</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Social Media -->
        <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-xl">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Follow Us</h3>
          
          <div class="grid grid-cols-2 gap-4">
            <a href="https://x.com/eplsummitng" class="flex items-center space-x-3 p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors group border border-gray-200">
              <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
                </svg>
              </div>
              <span class="text-gray-700 font-medium group-hover:text-blue-600 transition-colors">Twitter</span>
            </a>
            
            <a href="https://web.facebook.com/eplsummit" class="flex items-center space-x-3 p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors group border border-gray-200">
              <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </div>
              <span class="text-gray-700 font-medium group-hover:text-blue-600 transition-colors">Facebook</span>
            </a>
            
            <a href="https://www.linkedin.com/in/eplsummitng/" class="flex items-center space-x-3 p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors group border border-gray-200">
              <div class="w-10 h-10 bg-blue-700 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <span class="text-gray-700 font-medium group-hover:text-blue-700 transition-colors">LinkedIn</span>
            </a>
            
            <a href="https://www.instagram.com/eplsummitng/" class="flex items-center space-x-3 p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors group border border-gray-200">
              <div class="w-10 h-10 bg-gradient-to-br from-purple-500 via-pink-500 to-orange-500 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </div>
              <span class="text-gray-700 font-medium group-hover:text-pink-600 transition-colors">Instagram</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Footer -->
  <footer class="mt-24 border-t border-white/10 pt-12">
    <div class="container mx-auto px-6">
      <div class="text-center">
        <div class="flex items-center justify-center space-x-3 mb-6">
          <img src={emergingLogo.src} alt="Emerging Political Leaders Summit" class="h-16 w-auto" />
        </div>
        
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
          Empowering the next generation of political leaders through innovative discussions, meaningful connections, and transformative experiences.
        </p>
        
        <div class="flex flex-wrap justify-center gap-8 mb-8 text-sm">
          <a href="#" class="text-gray-400 hover:text-emerald-300 transition-colors">Privacy Policy</a>
          <a href="#" class="text-gray-400 hover:text-emerald-300 transition-colors">Terms of Service</a>
          <a href="#" class="text-gray-400 hover:text-emerald-300 transition-colors">Code of Conduct</a>
          <a href="#" class="text-gray-400 hover:text-emerald-300 transition-colors">Media Kit</a>
        </div>
        
        <div class="border-t border-white/10 pt-8">
          <p class="text-gray-500 text-sm">
            Copyright © 2026 Emerging Political Leaders Summit | Powered by <a href="https://david-bradford.vercel.app/" class="text-emerald-400 hover:text-emerald-300 transition-colors">Bradlee Designs</a>
          </p>
        </div>
      </div>
    </div>
  </footer>
</section>

<script>
  // Contact form submission handler
  const contactForm = document.getElementById('contactForm') as HTMLFormElement;
  const submitBtn = document.getElementById('contactSubmitBtn') as HTMLButtonElement;
  const successMessage = document.getElementById('contactSuccessMessage');
  const errorMessage = document.getElementById('contactErrorMessage');
  
  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const originalText = submitBtn.textContent;
    
    // Hide any previous messages
    successMessage?.classList.add('hidden');
    errorMessage?.classList.add('hidden');
    
    try {
      // Disable button and show loading state
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      
      // Submit form to Formspree
      const formData = new FormData(contactForm);
      const response = await fetch('https://formspree.io/f/mvzwapez', {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });
      
      if (response.ok) {
        // Show success message
        successMessage?.classList.remove('hidden');
        
        // Reset form
        contactForm.reset();
        
        // Hide success message after 5 seconds
        setTimeout(() => {
          successMessage?.classList.add('hidden');
        }, 5000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch (error) {
      console.error('Error:', error);
      
      // Show error message
      errorMessage?.classList.remove('hidden');
      
      // Hide error message after 5 seconds
      setTimeout(() => {
        errorMessage?.classList.add('hidden');
      }, 5000);
    } finally {
      // Re-enable button
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>